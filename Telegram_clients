// ✅ Нормализация
function normalize(str) { return String(str).toLowerCase().replace(/\s+/g, ""); }
function normalizeSerial(str) { return String(str).toUpperCase().replace(/\s+/g, ""); }
function parsePrice(str) { return parseFloat(str.replace(',', '.')); }

// 📅 Кнопки с датами
function sendDateButtons(chatId) {
  var buttons = [];
  var timezone = Session.getScriptTimeZone();
  var today = new Date();
  
  for (var i = 0; i < 7; i++) {
    var d = new Date();
    d.setDate(today.getDate() - i);
    var formatted = Utilities.formatDate(d, timezone, "yyyy-MM-dd");
    buttons.push([{ text: formatted, callback_data: "date_" + formatted }]);
  }
  buttons.push([{ text: "✏️ Ввести вручную", callback_data: "manual_date" }]);
  
  sendMessage(chatId, "📅 Выберите дату покупки:");
  // Отправляем кнопки отдельным сообщением
  UrlFetchApp.fetch(TELEGRAM_URL + "/sendMessage", {
    method: "post",
    contentType: "application/json",
    muteHttpExceptions: true,
    payload: JSON.stringify({
      chat_id: chatId,
      text: "👇 Нажмите на дату:",
      reply_markup: { inline_keyboard: buttons }
    })
  });
}

// 🔎 Проверка гарантии (быстрая)
function checkWarranty(chatId, date, model, serial, userName) {
  var lock = LockService.getScriptLock();
  if (!lock.tryLock(2000)) {
    sendMessage(chatId, "⏳ Система занята, попробуйте ещё раз");
    return;
  }
  
  try {
    var sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName("Доп Гарантия");
    if (!sheet) {
      sendMessage(chatId, "⚠️ Ошибка: лист не найден");
      sendInlineButton(chatId);
      return;
    }
    
    var lastRow = sheet.getLastRow();
    var data = sheet.getRange(2, 1, lastRow - 1, 4).getValues();
    var foundRow = -1;
    var timezone = Session.getScriptTimeZone();
    
    for (var i = 0; i < data.length; i++) {
      var rowDate = data[i][0] instanceof Date ? 
        Utilities.formatDate(data[i][0], timezone, "yyyy-MM-dd") : 
        String(data[i][0]).split('.').reverse().join('-');
      
      if (rowDate === date && 
          normalize(data[i][1]) === normalize(model) && 
          !String(data[i][2]).trim()) {
        foundRow = i;
        break;
      }
    }
    
    if (foundRow !== -1) {
      var row = foundRow + 2;
      if (sheet.getRange(row, 4).getValue() === true) {
        sendMessage(chatId, "⚠️ Гарантия уже подтверждена");
      } else {
        sheet.getRange(row, 3, 1, 2).setValues([[normalizeSerial(serial), true]]);
        sendMessage(chatId, "✅ Гарантия подтверждена!\nСпасибо!");
      }
    } else {
      sendMessage(chatId, "❌ Данные не найдены.\nПроверьте дату и модель");
    }
    
    // Очищаем шаги
    var props = PropertiesService.getScriptProperties();
    props.deleteProperty(`warranty_step_${chatId}`);
    props.deleteProperty(`warranty_date_${chatId}`);
    props.deleteProperty(`warranty_model_${chatId}`);
    
    sendInlineButton(chatId);
    
  } catch(error) {
    Logger.log(error);
    sendMessage(chatId, "⚠️ Ошибка");
  } finally {
    lock.releaseLock();
  }
}

// 📩 Обработка сообщений (как в вашем примере)
function handleMessage(msg) {
  if (!msg.text) return;
  var chatId = msg.chat.id;
  var text = msg.text;
  var userName = msg.from.first_name || "";
  
  if (text === "/start") {
    var props = PropertiesService.getScriptProperties();
    props.deleteProperty(`warranty_step_${chatId}`);
    props.deleteProperty(`warranty_date_${chatId}`);
    props.deleteProperty(`warranty_model_${chatId}`);
    sendInlineButton(chatId);
    return;
  }
  
  // ✅ ТА ЖЕ ЛОГИКА, ЧТО И В ВАШЕМ ПРИМЕРЕ!
  var warrantyStep = getWithTTL(`warranty_step_${chatId}`);
  
  if (warrantyStep === 'ask_model') {
    setWithTTL(`warranty_model_${chatId}`, text, 300);
    setWithTTL(`warranty_step_${chatId}`, 'ask_serial', 300);
    sendMessage(chatId, "🔢 Введите серийный номер:");
    return;
  }
  
  if (warrantyStep === 'ask_serial') {
    var serial = text;
    var date = getWithTTL(`warranty_date_${chatId}`);
    var model = getWithTTL(`warranty_model_${chatId}`);
    
    if (!date || !model) {
      sendMessage(chatId, "❌ Сессия устарела. Нажмите /start");
      return;
    }
    
    sendMessage(chatId, "🔍 Проверяем...");
    checkWarranty(chatId, date, model, serial, userName);
    return;
  }
  
  // Ручной ввод даты
  if (warrantyStep === 'ask_date_manual') {
    if (!/^\d{4}-\d{2}-\d{2}$/.test(text)) {
      sendMessage(chatId, "❗ Формат: ГГГГ-ММ-ДД\nПример: 2024-03-15");
      return;
    }
    setWithTTL(`warranty_date_${chatId}`, text, 300);
    setWithTTL(`warranty_step_${chatId}`, 'ask_model', 300);
    sendMessage(chatId, "📱 Укажите модель устройства:");
    return;
  }
  
  // Если нет активного шага
  sendMessage(chatId, "Нажмите /start");
}

// 🔘 Обработка кнопок
function handleCallback(query) {
  // Мгновенный ответ
  try {
    UrlFetchApp.fetch(TELEGRAM_URL + "/answerCallbackQuery", {
      method: "post",
      contentType: "application/json",
      muteHttpExceptions: true,
      payload: JSON.stringify({ callback_query_id: query.id })
    });
  } catch(e) {}
  
  var chatId = query.message.chat.id;
  var data = query.data;
  
  if (data === "confirm_service") {
    sendDateButtons(chatId);
    return;
  }
  
  if (data === "manual_date") {
    setWithTTL(`warranty_step_${chatId}`, 'ask_date_manual', 300);
    sendMessage(chatId, "✏️ Введите дату в формате ГГГГ-ММ-ДД\nПример: 2024-03-15");
    return;
  }
  
  if (data.startsWith("date_")) {
    var selectedDate = data.replace("date_", "");
    setWithTTL(`warranty_date_${chatId}`, selectedDate, 300);
    setWithTTL(`warranty_step_${chatId}`, 'ask_model', 300);
    sendMessage(chatId, "📱 Укажите модель устройства:");
    return;
  }
}

// 🚀 doPost
function doPost(e) {
  try {
    var contents = JSON.parse(e.postData.contents);
    
    // Защита от дублей
    var updateId = contents.update_id;
    var props = PropertiesService.getScriptProperties();
    var lastId = props.getProperty("last_update_id");
    if (lastId && Number(updateId) <= Number(lastId)) {
      return ContentService.createTextOutput("ok");
    }
    props.setProperty("last_update_id", updateId);
    
    if (contents.callback_query) {
      handleCallback(contents.callback_query);
    } else if (contents.message) {
      handleMessage(contents.message);
    }
    
  } catch(e) {
    Logger.log(e);
  }
  
  return ContentService.createTextOutput("ok");
}
