// 🔎 Проверка гарантии (быстрая)
function getOpenWarrantyRowsMap(sheet) {
  var cache = CacheService.getScriptCache();
  var cached = cache.get(WARRANTY_INDEX_CACHE_KEY);
  if (cached) {
    try { return JSON.parse(cached); } catch(e) {}
  }

  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return {};

  var data = sheet.getRange(2, 1, lastRow - 1, 3).getValues();
  var timezone = Session.getScriptTimeZone();
  var rowsMap = {};

  for (var i = 0; i < data.length; i++) {
    var rowDate = data[i][0] instanceof Date ?
      Utilities.formatDate(data[i][0], timezone, "yyyy-MM-dd") :
      String(data[i][0]).split('.').reverse().join('-');
    var model = normalize(data[i][1]);
    var serial = String(data[i][2]).trim();

    if (!serial && rowDate && model) {
      var key = buildWarrantyLookupKey(rowDate, model);
      if (!rowsMap[key]) rowsMap[key] = i + 2;
    }
  }

  cache.put(WARRANTY_INDEX_CACHE_KEY, JSON.stringify(rowsMap), WARRANTY_INDEX_TTL_SECONDS);
  return rowsMap;
}

function invalidateWarrantyRowsCache() {
  CacheService.getScriptCache().remove(WARRANTY_INDEX_CACHE_KEY);
}

function checkWarranty(chatId, date, model, serial) {
  try {
    var sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(SHEET_NAME);
    if (!sheet) {
      sendMessage(chatId, "⚠️ Ошибка: лист не найден");
      sendInlineButton(chatId);
      return;
    }

    var row = getOpenWarrantyRowsMap(sheet)[buildWarrantyLookupKey(date, model)] || -1;
    if (row !== -1) {
      var lock = LockService.getDocumentLock();
      if (!lock.tryLock(1500)) {
        sendMessage(chatId, "⏳ Система занята, попробуйте ещё раз");
        return;
      }

      try {
        var existingSerial = String(sheet.getRange(row, 3).getValue()).trim();
        if (existingSerial) {
          sendMessage(chatId, "⚠️ Гарантия уже подтверждена");
          return;
        }

        sheet.getRange(row, 3, 1, 2).setValues([[normalizeSerial(serial), true]]);
        invalidateWarrantyRowsCache();
        sendMessage(chatId, "✅ Гарантия подтверждена!\nСпасибо!");
      } finally {
        lock.releaseLock();
      }
    } else {
      sendMessage(chatId, "❌ Данные не найдены.\nПроверьте дату и модель");
    }

  } catch(error) {
    Logger.log(error);
    sendMessage(chatId, "⚠️ Ошибка");
  }
}

// 📩 Обработка сообщений (как в вашем примере)
function handleMessage(msg) {
  if (!msg.text) return;
  var chatId = msg.chat.id;
  var userId = msg.from.id;
  var text = msg.text;
  
  if (text === "/start") {
    clearSession(chatId, userId);
    sendInlineButton(chatId);
    return;
  }
  
  // ✅ ТА ЖЕ ЛОГИКА, ЧТО И В ВАШЕМ ПРИМЕРЕ!
  var stepKey = buildSessionKey(chatId, userId, "step");
  var dateKey = buildSessionKey(chatId, userId, "date");
  var modelKey = buildSessionKey(chatId, userId, "model");
  var warrantyStep = getWithTTL(stepKey);
  
  if (warrantyStep === 'ask_model') {
    setWithTTL(modelKey, text, SESSION_TTL_SECONDS);
    setWithTTL(stepKey, 'ask_serial', SESSION_TTL_SECONDS);
    sendMessage(chatId, "🔢 Введите серийный номер:");
    return;
  }
  
  if (warrantyStep === 'ask_serial') {
    var serial = text;
    var date = getWithTTL(dateKey);
    var model = getWithTTL(modelKey);
    
    if (!date || !model) {
      sendMessage(chatId, "❌ Сессия устарела. Нажмите /start");
      return;
    }
    
    sendMessage(chatId, "🔍 Проверяем...");
    checkWarranty(chatId, date, model, serial);
    clearSession(chatId, userId);
    sendInlineButton(chatId);
    return;
  }
  
  // Ручной ввод даты
  if (warrantyStep === 'ask_date_manual') {
    if (!/^\d{4}-\d{2}-\d{2}$/.test(text)) {
      sendMessage(chatId, "❗ Формат: ГГГГ-ММ-ДД\nПример: 2024-03-15");
      return;
    }
    setWithTTL(dateKey, text, SESSION_TTL_SECONDS);
    setWithTTL(stepKey, 'ask_model', SESSION_TTL_SECONDS);
    sendMessage(chatId, "📱 Укажите модель устройства:");
    return;
  }
  
  // Если нет активного шага
  sendMessage(chatId, "Нажмите /start");
}

// 🔘 Обработка кнопок
function handleCallback(query) {
  // Мгновенный ответ
  try {
    UrlFetchApp.fetch(TELEGRAM_URL + "/answerCallbackQuery", {
      method: "post",
      contentType: "application/json",
      muteHttpExceptions: true,
      payload: JSON.stringify({ callback_query_id: query.id })
    });
  } catch(e) {}
  
  var chatId = query.message.chat.id;
  var userId = query.from.id;
  var data = query.data;
  var stepKey = buildSessionKey(chatId, userId, "step");
  var dateKey = buildSessionKey(chatId, userId, "date");
  
  if (data === "confirm_service") {
    sendDateButtons(chatId);
    return;
  }
  
  if (data === "manual_date") {
    setWithTTL(stepKey, 'ask_date_manual', SESSION_TTL_SECONDS);
    sendMessage(chatId, "✏️ Введите дату в формате ГГГГ-ММ-ДД\nПример: 2024-03-15");
    return;
  }
  
  if (data.startsWith("date_")) {
    var selectedDate = data.replace("date_", "");
    setWithTTL(dateKey, selectedDate, SESSION_TTL_SECONDS);
    setWithTTL(stepKey, 'ask_model', SESSION_TTL_SECONDS);
    sendMessage(chatId, "📱 Укажите модель устройства:");
    return;
  }
}

// 🚀 doPost
function doPost(e) {
  try {
    var contents = JSON.parse(e.postData.contents);
    
    // Защита от дублей
    var updateId = contents.update_id;
    var dedupKey = "update_id_" + updateId;
    var dedupCache = CacheService.getScriptCache();
    if (dedupCache.get(dedupKey)) {
      return ContentService.createTextOutput("ok");
    }
    dedupCache.put(dedupKey, "1", UPDATE_DEDUP_TTL_SECONDS);
    
    if (contents.callback_query) {
      handleCallback(contents.callback_query);
    } else if (contents.message) {
      handleMessage(contents.message);
    }
    
  } catch(e) {
    Logger.log(e);
  }
  
  return ContentService.createTextOutput("ok");
}
