// 📦 Работа с состоянием
function setUserState(chatId, state, data) {
  var props = PropertiesService.getScriptProperties();
  props.setProperty("state_" + chatId, JSON.stringify({ state: state, data: data || {} }));
}

function getUserState(chatId) {
  var props = PropertiesService.getScriptProperties();
  var raw = props.getProperty("state_" + chatId);
  return raw ? JSON.parse(raw) : null;
}

function clearUserState(chatId) {
  PropertiesService.getScriptProperties().deleteProperty("state_" + chatId);
}

