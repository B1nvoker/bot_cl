// ================= ОСНОВНОЙ ВЕБХУК =================
function doPost(e) {
  try {
    if (!e || !e.postData) {
      return ContentService.createTextOutput(JSON.stringify({ ok: true })).setMimeType(ContentService.MimeType.JSON);
    }

    const contents = JSON.parse(e.postData.contents);
    const updateId = contents.update_id;
    const lastUpdateId = cache.get(LAST_UPDATE_KEY);
    
    if (lastUpdateId && parseInt(lastUpdateId) >= updateId) {
      return ContentService.createTextOutput(JSON.stringify({ ok: true })).setMimeType(ContentService.MimeType.JSON);
    }
    
    cache.put(LAST_UPDATE_KEY, updateId.toString(), 3600);

    if (contents.callback_query) handleCallback(contents.callback_query);
    if (contents.message) handleMessage(contents.message);

    return ContentService.createTextOutput(JSON.stringify({ ok: true })).setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    console.error(`doPost error: ${err.toString()}`);
    return ContentService.createTextOutput(JSON.stringify({ error: err.toString() })).setMimeType(ContentService.MimeType.JSON);
  }
}

