// ================= ОБРАБОТЧИК СООБЩЕНИЙ =================
function handleMessage(msg) {
  const chatId = msg.chat.id.toString();
  const text = msg.text ? msg.text.trim() : '';
  const userId = msg.from.id.toString();
  
  if (!text) return;
  console.log(`USER: ${userId} | CHAT: ${chatId} | MSG: ${text}`);

  if (text === '/start') {
    showMainMenu(chatId);
    return;
  }

  const userState = getState(chatId);
  if (!userState || !userState.state) {
    sendMessage(chatId, 'Пожалуйста, начните с команды /start');
    return;
  }

  const currentState = userState.state;
  const sessionData = userState.data || {};

  // ================= ЛОГИКА МАГАЗИНА =================
  if (currentState === STATE.SHOP_ASK_QUERY) {
    if (text.length < 2) {
      sendMessage(chatId, '❗ Запрос слишком короткий. Введите название или код товара.');
      return;
    }
    setState(chatId, { state: STATE.SHOP_PROCESSING, data: sessionData });
    sendMessage(chatId, '⏳ Ищу товар...');
    processShopSearch(chatId, text);
    return;
  }

  if (currentState === STATE.SHOP_PROCESSING) {
    sendMessage(chatId, '⚠️ Подождите, поиск еще не завершен.');
    return;
  }

  // ================= ЛОГИКА ГАРАНТИИ =================
  if (currentState === STATE.ASK_DATE) {
    const dateRegex = /^\d{2}\.\d{2}\.\d{4}$/;
    if (!dateRegex.test(text)) {
      sendMessage(chatId, '❗ Неверный формат даты\nВведите дату в формате *DD.MM.YYYY*\n\nПример: *15.04.2024*');
      return;
    }
    const parts = text.split('.');
    const inputDate = `${parts[2]}-${parts[1]}-${parts[0]}`;
    const date = new Date(inputDate);
    if (isNaN(date.getTime())) {
      sendMessage(chatId, '❗ Такой даты не существует\nВведите дату в формате *DD.MM.YYYY*');
      return;
    }
    const purchaseDate = new Date(inputDate);
    const now = new Date();
    const diffDays = Math.floor((now - purchaseDate) / (1000 * 60 * 60 * 24));
    if (diffDays > 14) {
      sendMessage(chatId, '⚠️ *Срок подтверждения гарантии истёк*\n\nПодтверждение возможно в течение *14 дней* после покупки.\n\n📅 Прошло дней: *' + diffDays + '*\n📆 Дата покупки: *' + text + '*\n\nК сожалению, гарантия больше не может быть активирована.');
      clearState(chatId);
      return;
    }
    sessionData.date = inputDate;
    setState(chatId, { state: STATE.ASK_MODEL, data: sessionData });
    sendMessage(chatId, '📦 Введите точную модель товара:');
    return;
  }

  if (currentState === STATE.ASK_MODEL) {
    if (text.length < 2) { sendMessage(chatId, '❗ Название модели слишком короткое.'); return; }
    sessionData.model = text;
    setState(chatId, { state: STATE.ASK_SERIAL, data: sessionData });
    sendMessage(chatId, '🔢 *Введите серийный номер устройства*\n\n📍 Где его найти:\n• на корпусе устройства\n• на упаковке (коробке)\n• в гарантийном талоне\n\n✍️ Введите номер точно, как указано');
    return;
  }

  if (currentState === STATE.ASK_SERIAL) {
    if (text.length < 3) { sendMessage(chatId, '❗ Серийный номер слишком короткий.'); return; }
    sessionData.serial = text.trim();
    setState(chatId, { state: STATE.PROCESSING, data: sessionData });
    sendMessage(chatId, '⏳ Проверяю данные...');
    processGuarantee(chatId, sessionData.date, sessionData.model, sessionData.serial);
    return;
  }

  if (currentState === STATE.PROCESSING) { sendMessage(chatId, '⚠️ Подождите, идёт проверка предыдущего запроса.'); return; }

  // ================= ЛОГИКА ЗАЯВКИ НА ОБСЛУЖИВАНИЕ =================
  if (currentState === STATE.REPAIR_ASK_FIO) {
    if (text.length < 3) { sendMessage(chatId, '❗ ФИО слишком короткое. Введите полностью.'); return; }
    sessionData.fio = text;
    setState(chatId, { state: STATE.REPAIR_ASK_PHONE, data: sessionData });
    sendMessage(chatId, '📱 Введите ваш *номер телефона*:\n\nПример: +37529xxxxxxx');
    return;
  }

  if (currentState === STATE.REPAIR_ASK_PHONE) {
    const cleanPhone = text.replace(/[^0-9+]/g, '');
    if (cleanPhone.length < 13) { sendMessage(chatId, '❗ Номер телефона выглядит некорректно.\nВведите номер в формате: +37529xxxxxxx'); return; }
    sessionData.phone = cleanPhone;
    setState(chatId, { state: STATE.REPAIR_ASK_MODEL, data: sessionData });
    sendMessage(chatId, '📦 Введите *наименование модели* устройства, которое сломалось:');
    return;
  }

  if (currentState === STATE.REPAIR_ASK_MODEL) {
    if (text.length < 2) { sendMessage(chatId, '❗ Название модели слишком короткое.'); return; }
    sessionData.model = text;
    setState(chatId, { state: STATE.REPAIR_ASK_SERIAL, data: sessionData });
    sendMessage(chatId, '🔢 Введите *серийный номер* устройства:');
    return;
  }

  if (currentState === STATE.REPAIR_ASK_SERIAL) {
    if (text.length < 3) { sendMessage(chatId, '❗ Серийный номер слишком короткий.'); return; }
    sessionData.serial = text.trim();
    setState(chatId, { state: STATE.REPAIR_ASK_DESC, data: sessionData });
    sendMessage(chatId, '📝 *Опишите проблему*\n\nПостарайтесь максимально подробно рассказать:\n• что произошло\n• при каких обстоятельствах\n• какие ошибки отображаются на экране (если есть)');
    return;
  }

  if (currentState === STATE.REPAIR_ASK_DESC) {
    if (text.length < 5) { sendMessage(chatId, '❗ Описание слишком короткое. Пожалуйста, опишите проблему подробнее (минимум 10 символов).'); return; }
