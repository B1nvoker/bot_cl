// 🔎 Проверка гарантии
function checkWarranty(chatId, user) {
  var lock = LockService.getScriptLock();
  var lockAcquired = false;
  
  try {
    if (!lock.tryLock(3000)) {
      sendMessage(chatId, "⏳ Система занята, попробуйте ещё раз через пару секунд");
      return;
    }
    lockAcquired = true;
    
    var sheet = getSheet(); // ⚡ используем кэш
    
    if (!sheet) {
      sendMessage(chatId, "⚠️ Ошибка: лист 'Доп Гарантия' не найден");
      clearUserState(chatId);
      sendInlineButton(chatId);
      return;
    }

    var lastRow = sheet.getLastRow();
    if (lastRow <= 1) {
      sendMessage(chatId, "❌ Данные не найдены. Таблица пуста.");
      clearUserState(chatId);
      sendInlineButton(chatId);
      return;
    }
    
    var data = sheet.getRange(2, 1, lastRow - 1, 4).getValues();
    var foundRow = -1;
    var timezone = Session.getScriptTimeZone();

    for (var i = 0; i < data.length; i++) {
      var rawDate = data[i][0];
      var date = normalizeDate(rawDate, timezone);

      var model = data[i][1];
      var serialExists = data[i][2];

      if (date === user.date && 
          normalize(model) === normalize(user.model) && 
          isEmptySerial(serialExists)) {
        foundRow = i;
        break;
      }
    }

    if (foundRow !== -1) {
      var row = foundRow + 2;

      var isConfirmed = sheet.getRange(row, 4).getValue();

      if (isConfirmed === true) {
        sendMessage(chatId, "⚠️ Гарантия уже была подтверждена ранее для этого устройства.");
        clearUserState(chatId);
        sendInlineButton(chatId);
        return;
      }

      var normalizedSerial = normalizeSerial(user.serial);
      sheet.getRange(row, 3, 1, 2).setValues([[normalizedSerial, true]]);

      sendMessage(chatId, "✅ Ваша дополнительная гарантия подтверждена!\n\nСпасибо за обращение!");
      
      sendInlineButton(chatId);
    } else {
      sendMessage(chatId, "❌ Данные не найдены.\n\nПроверьте:\n• Дату покупки\n• Модель устройства\n\nЕсли данные верны, обратитесь в поддержку.");
      
      sendInlineButton(chatId);
    }

    clearUserState(chatId);
  } catch (error) {
    Logger.log("Ошибка в checkWarranty: " + error.toString());
    sendMessage(chatId, "⚠️ Произошла техническая ошибка. Пожалуйста, попробуйте позже.");
    clearUserState(chatId);
  } finally {
    if (lockAcquired && lock.hasLock()) {
      lock.releaseLock();
    }
  }
}

// 📩 Обработка сообщений
function handleMessage(msg) {
  if (!msg.text) return;
  
  var chatId = msg.chat.id;
  var text = msg.text;

  if (text === "/start") {
    clearUserState(chatId);
    sendInlineButton(chatId);
    return;
  }

  var user = getUserState(chatId);
  
  if (!user) {
    sendMessage(chatId, "Пожалуйста, начните с команды /start");
    return;
  }

  switch (user.state) {
    case "WAIT_DATE_MANUAL":
      if (!isValidDate(text)) {
        sendMessage(chatId, "❗ Пожалуйста, введите дату в формате ГГГГ-ММ-ДД\nНапример: 2024-03-15");
        return;
      }
      user.data.date = text;
      setUserState(chatId, "WAIT_MODEL", user.data);
      sendMessage(chatId, "📱 Пожалуйста, укажите модель устройства:");
      break;

    case "WAIT_MODEL":
      if (!text || text.trim() === "") {
        sendMessage(chatId, "❗ Пожалуйста, укажите модель устройства:");
        return;
      }
      user.data.model = text;
      setUserState(chatId, "WAIT_SERIAL", user.data);
      sendMessage(chatId, "🔢 Пожалуйста, введите серийный номер:");
      break;

    case "WAIT_SERIAL":
      if (text.length < 5) {
        sendMessage(chatId, "❗ Серийный номер слишком короткий. Пожалуйста, введите полный серийный номер:");
        return;
      }
      user.data.serial = text;
      sendMessage(chatId, "🔍 Проверяем данные...");
      checkWarranty(chatId, user.data);
      break;
      
    default:
      sendMessage(chatId, "⚠️ Неизвестная команда. Начните с /start");
      clearUserState(chatId);
  }
}

// 🔘 Обработка кнопок (ГЛАВНОЕ ИСПРАВЛЕНИЕ ЗДЕСЬ)
function handleCallback(query) {
  // ✅ КРИТИЧЕСКИ ВАЖНО: используем chatId из сообщения, а не from.id
  var chatId = query.message.chat.id;
  var data = query.data;

  answerCallback(query.id);

  // ✅ Защита от "чужого" callback (когда состояние не найдено)
  var user = getUserState(chatId);
  
  if (data === "confirm_service") {
    sendDateButtons(chatId);
    return;
  }

  // ✅ Проверяем, что сессия не устарела
  if (data.startsWith("date_") || data === "manual_date") {
    if (!user) {
      sendMessage(chatId, "❗ Сессия устарела. Пожалуйста, нажмите /start и начните заново.");
      return;
    }
  }

  if (data.startsWith("date_")) {
    var selectedDate = data.replace("date_", "");
    setUserState(chatId, "WAIT_MODEL", { date: selectedDate });
    sendMessage(chatId, "📱 Пожалуйста, укажите модель устройства:");
    return;
  }

  if (data === "manual_date") {
    setUserState(chatId, "WAIT_DATE_MANUAL", {});
    sendMessage(chatId, "✏️ Введите дату покупки вручную\nФормат: ГГГГ-ММ-ДД\nНапример: 2024-03-15");
    return;
  }
}

// 🚀 doPost
function doPost(e) {
  var contents;
  try {
    contents = JSON.parse(e.postData.contents);
  } catch (err) {
    Logger.log("Ошибка парсинга JSON: " + err.toString());
    return ContentService.createTextOutput("invalid json");
  }
  
  if (!contents.message && !contents.callback_query) {
    return ContentService.createTextOutput("ok");
  }
  
  // ✅ Обработка
  if (contents.callback_query) {
    handleCallback(contents.callback_query);
  } else if (contents.message) {
    handleMessage(contents.message);
  }

  // 📊 Веб-форма
  if (contents.name && contents.phone) {
    try {
      var sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName("Лист1");
      if (sheet) {
        sheet.appendRow([
          contents.name,
          contents.phone,
          contents.comment || "",
          new Date()
        ]);
      }
    } catch (error) {
      Logger.log("Ошибка записи в таблицу: " + error.toString());
    }
  }

  return ContentService.createTextOutput("ok");
}
