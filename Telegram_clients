// ================= ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =================
function formatDate(date) {
  if (!date) return '';
  const d = new Date(date);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

function formatCurrentDate() { return formatDate(new Date()); }

function normalize(str) { return str.toLowerCase().replace(/\s+/g, ' ').trim(); }

function normalizeSerial(str) { return str.replace(/\s+/g, '').toUpperCase(); }

function formatPrice(price) {
  const num = parseFloat(price);
  if (isNaN(num)) return "Цена не указана";
  const rubles = Math.floor(num);
  const kopecks = Math.round((num - rubles) * 100);
  const formattedRubles = rubles.toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ");
  return `${formattedRubles}.${kopecks.toString().padStart(2, '0')}`;
}

// ================= ЛОГИКА ПОИСКА В МАГАЗИНЕ (ОПТИМИЗАЦИЯ ПОД 50К+ СТРОК) =================
function processShopSearch(chatId, query) {
  try {
    const sheet = SpreadsheetApp.openById(SHOP_SPREADSHEET_ID).getSheetByName(SHOP_SHEET_NAME);
    if (!sheet) throw new Error('Лист "' + SHOP_SHEET_NAME + '" не найден!');

    const cleanQuery = query.trim().toLowerCase();
    const isNumericQuery = /^\d+$/.test(cleanQuery);

    // 1. Читаем ТОЛЬКО заголовки (1 строка), чтобы найти номера столбцов
    const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
    const colMap = {};
    headers.forEach(function(h, i) {
      if(h) {
        colMap[h.toString().toLowerCase().trim()] = i + 1; // +1 т.к. getColumn() считает с 1
      }
    });

    const colModel = colMap['model'] || 0;
    const colPrice = colMap['price'] || 0;
    const colPriceBn = colMap['price_bn'] || 0;
    const colDelivery = colMap['delivery_day'] || 0;
    const colId = colMap['onliner_id'] || 0;
    const colUrl = colMap['onliner_url'] || 0;

    if (!colModel || !colPrice) {
      throw new Error('Не найдены столбцы model или price');
    }

    let foundRows = [];

    if (isNumericQuery) {
      // ПОИСК ПО ЦИФРАМ (onliner_id)
      const textFinder = sheet.createTextFinder(cleanQuery);
      textFinder.findAll().forEach(function(cell) {
        if (foundRows.length >= 10) return;
        if (cell.getColumn() === colId) {
          foundRows.push(cell.getRow());
        }
      });
    } else {
      // ПОИСК ПО ТЕКСТУ (model)
      const textFinder = sheet.createTextFinder(cleanQuery).matchCase(false);
      textFinder.findAll().forEach(function(cell) {
        if (foundRows.length >= 10) return;
        if (cell.getColumn() === colModel) {
          if (foundRows.indexOf(cell.getRow()) === -1) { // Защита от дубликатов
            foundRows.push(cell.getRow());
          }
        }
      });
    }

    if (foundRows.length === 0) {
      // Кнопка "Назад" даже если ничего не найдено
      const errorKeyboard = {
        inline_keyboard: [[{ text: '⬅️ Назад', callback_data: 'menu_store' }]]
      };
      sendMessage(chatId, 
        '❌ *Товары не найдены*\n\nПроверьте правильность написания или попробуйте другой запрос.', 
        errorKeyboard
      );
      clearState(chatId);
      return;
    }

    // 2. Собираем данные ТОЛЬКО из найденных строк
    let responseText = '🔍 *Найдено товаров: ' + foundRows.length + '*\n\n';
    
    foundRows.forEach(function(rowNum) {
      const getVal = function(col) {
        if (!col) return '';
        try {
          const val = sheet.getRange(rowNum, col).getValue();
          if (!val || val.toString() === '#N/A') return '';
          return val.toString().trim();
        } catch(e) { return ''; }
      };

      const model = getVal(colModel);
      let price = getVal(colPrice) || '0';
      const priceBn = getVal(colPriceBn) || '0';
      const delivery = getVal(colDelivery);
      const url = getVal(colUrl);

      // Если базовая цена 0, берем цену БН
      if (price === '0') price = priceBn;

      // УМНОЖАЕМ ЦЕНУ НА 3 И ФОРМАТИРУЕМ
      const numPrice = parseFloat(price) * 3;
      const formattedPrice = formatPrice(numPrice);

      // Формируем строку доставки
      let deliveryText = 'Сроки доставки: уточняйте';
      if (delivery) {
        deliveryText = '🚚 Сроки доставки (РБ +1 день): ' + delivery + ' дня';
      }

      const urlBlock = url ? '🔗 [Ссылка на Онлайнер](' + url + ')' : '⚠️ Ссылка на Онлайнер отсутствует';

      responseText += 
        '📦 *' + model + '*\n' +
        '💰 ' + formattedPrice + ' руб.\n' +
        deliveryText + '\n' +
        urlBlock + '\n\n';
    });

    if (foundRows.length === 10) {
       responseText += '_Показаны первые 10 результатов. Уточните запрос для более точного поиска._\n\n';
    }

    responseText += '💡 Для оформления заказа напишите менеджеру:\n📩 https://t.me/infotufby';

    // Добавляем кнопку "Назад" к успешному результату
    const successKeyboard = {
      inline_keyboard: [[{ text: '🔍 Новый поиск', callback_data: 'store_check_price' }, { text: '⬅️ Назад', callback_data: 'menu_store' }]]
    };

    sendMessage(chatId, responseText, successKeyboard);
    clearState(chatId);

  } catch (error) {
    console.error('ERROR in processShopSearch: ' + error.toString());
    sendMessage(chatId, '⚠️ Произошла ошибка при поиске товара. Попробуйте позже.');
    clearState(chatId);
  }
}

// ================= ЛОГИКА ЗАЯВКИ НА РЕМОНТ =================
function processRepairRequest(chatId, data) {
  try {
    const lock = LockService.getScriptLock();
    try {
      lock.waitLock(5000);
      const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(REPAIR_SHEET_NAME);
      if (!sheet) throw new Error(`Лист "${REPAIR_SHEET_NAME}" не найден!`);

      sheet.appendRow([formatCurrentDate(), data.fio, "'" + data.phone, data.model, data.serial, data.description]);
      sendNotification(data);

      sendMessage(chatId,
        `✅ *Заявка на обслуживание успешно создана!*\n\n` +
        `📋 *Данные заявки:*\n👤 Клиент: *${data.fio}*\n📞 Телефон: *${data.phone}*\n📦 Модель: *${data.model}*\n🔢 Серийный номер: *${data.serial}*\n💬 Проблема: _${data.description}_\n\n` +
        `📌 Наш специалист свяжется с вами в ближайшее время для уточнения деталей.\n\nПо всем вопросам пишите https://t.me/infotufby 📩`
      );
    } catch (lockError) {
      console.error(`Lock error: ${lockError.toString()}`);
      sendMessage(chatId, '⚠️ Система временно занята. Пожалуйста, попробуйте через минуту.');
    } finally {
      lock.releaseLock();
    }
    clearState(chatId);
  } catch (error) {
    console.error(`ERROR in processRepairRequest: ${error.toString()}`);
    sendMessage(chatId, '⚠️ Произошла ошибка при сохранении заявки. Попробуйте позже.');
    clearState(chatId);
  }
}

function sendNotification(data) {
