    sendMessage(ADMIN_CHAT_ID, 
      `🚨 *У вас новая заявка на гарантийное обслуживание!*\n\n👤 *Клиент:* ${data.fio}\n📞 *Телефон:* ${data.phone}\n📦 *Модель:* ${data.model}\n🔢 *Серийный номер:* ${data.serial}\n💬 *Проблема:* _${data.description}_`
    );
  } catch (e) {
    console.error(`Failed to send admin notification: ${e.toString()}`);
  }
}

// ================= ЛОГИКА ПРОВЕРКИ ГАРАНТИИ =================
function processGuarantee(chatId, inputDate, inputModel, inputSerial) {
  try {
    let sheetData = cache.get(CACHE_SHEET_KEY);
    let dataRows;
    
    if (sheetData) {
      dataRows = JSON.parse(sheetData);
    } else {
      const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(SHEET_NAME);
      if (!sheet) throw new Error('Sheet not found');
      const range = sheet.getDataRange();
      const values = range.getValues();
      
      if (values.length <= 1) { dataRows = []; } 
      else {
        dataRows = values.slice(1).map((row, i) => ({
          date: formatDate(row[0]), model: normalize(row[1]), serial: row[2] ? normalizeSerial(row[2].toString()) : '', status: row[3] ? row[3].toString().trim() : '', rowNumber: i + 2 
        }));
      }
      cache.put(CACHE_SHEET_KEY, JSON.stringify(dataRows), 60);
    }

    const cleanModel = normalize(inputModel);
    const cleanSerial = normalizeSerial(inputSerial);
    
    for (let row of dataRows) {
      if (row.serial === cleanSerial && row.status === 'CONFIRMED') {
        sendMessage(chatId, '⚠️ *Этот серийный номер уже зарегистрирован*\n\nКаждое устройство можно зарегистрировать только один раз.\n\nЕсли вы считаете, что это ошибка, обратитесь в поддержку.');
        clearState(chatId); return;
      }
    }
    
    let foundRow = null;
    for (let row of dataRows) {
      if (row.date === inputDate && row.model === cleanModel && (row.serial === cleanSerial || row.serial === '' || !row.serial)) {
        foundRow = row; break;
      }
    }

    if (!foundRow) {
      sendMessage(chatId, `❌ *Товар не найден*\n\n📌 Проверьте:\n• дату покупки\n• точное название модели\n• серийный номер\n\n🔄 Попробуйте снова: /start`);
      clearState(chatId); return;
    }

    if (foundRow.status === 'CONFIRMED') {
      sendMessage(chatId, '⚠️ Гарантия уже была подтверждена ранее');
      clearState(chatId); return;
    }

    const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(SHEET_NAME);
    const lock = LockService.getScriptLock();
    
    try {
      lock.waitLock(5000); 
      if (!foundRow.serial || foundRow.serial === '') sheet.getRange(foundRow.rowNumber, 3).setValue(cleanSerial);
      sheet.getRange(foundRow.rowNumber, 4).setValue('CONFIRMED');
      cache.remove(CACHE_SHEET_KEY);
      
      const formattedDate = inputDate.split('-').reverse().join('.');
      sendMessage(chatId, `✅ *Гарантия успешно подтверждена!*\n\n🎉 Спасибо за покупку и доверие!\n\n📦 Модель: *${inputModel}*\n🔢 Серийный номер: *${inputSerial}*\n📅 Дата покупки: *${formattedDate}*\n\n📌 Ваше устройство теперь находится на гарантии.\n\nПо всем вопросам пишите https://t.me/infotufby 📩`);
    } catch (lockError) {
      console.error(`Lock error: ${lockError.toString()}`);
      sendMessage(chatId, '⚠️ Система временно занята. Пожалуйста, попробуйте через минуту.');
    } finally {
      lock.releaseLock();
    }
    clearState(chatId);
  } catch (error) {
    console.error(`ERROR in processGuarantee: ${error.toString()}`);
    sendMessage(chatId, '⚠️ Произошла ошибка при обращении к базе данных. Попробуйте позже.');
    clearState(chatId);
  }
}

// ================= РАБОТА СО СОСТОЯНИЯМИ И ОТПРАВКА =================
function getState(chatId) {
  const data = cache.get(`session_${chatId}`);
  return data ? JSON.parse(data) : null;
}

function setState(chatId, stateData) {
  stateData.updated_at = new Date().toISOString();
  cache.put(`session_${chatId}`, JSON.stringify(stateData), SESSION_TTL);
}

function clearState(chatId) { cache.remove(`session_${chatId}`); }

function sendMessage(chatId, text, keyboard = null) {
  const url = `https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`;
  const payload = { chat_id: chatId, text: text, parse_mode: 'Markdown', disable_web_page_preview: false };
  if (keyboard) payload.reply_markup = keyboard;
  
  try {
    UrlFetchApp.fetch(url, { method: 'post', contentType: 'application/json', payload: JSON.stringify(payload), muteHttpExceptions: true });
  } catch (e) {
    console.error(`ERROR sending message: ${e}`);
  }
}
