// ✅ Нормализация
function normalize(str) { return String(str).toLowerCase().replace(/\s+/g, ""); }
function normalizeSerial(str) { return String(str).toUpperCase().replace(/\s+/g, ""); }
function parsePrice(str) { return parseFloat(str.replace(',', '.')); }
function buildSessionKey(chatId, userId, field) { return "warranty_" + field + "_" + chatId + "_" + userId; }
function buildWarrantyLookupKey(date, model) { return date + "|" + normalize(model); }

function clearSession(chatId, userId) {
  var props = PropertiesService.getScriptProperties();
  var cache = CacheService.getScriptCache();
  var keys = [
    buildSessionKey(chatId, userId, "step"),
    buildSessionKey(chatId, userId, "date"),
    buildSessionKey(chatId, userId, "model")
  ];

  for (var i = 0; i < keys.length; i++) {
    props.deleteProperty(keys[i]);
    cache.remove(keys[i]);
  }
}

